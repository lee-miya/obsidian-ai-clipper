#!/usr/bin/env bash
# Generate a review package file containing commit list, diff stat, and full diff.
# Usage: review-package BASE HEAD

BASE="$1"
HEAD="$2"

if [ -z "$BASE" ] || [ -z "$HEAD" ]; then
  echo "Usage: $0 <base-ref> <head-ref>"
  exit 1
fi

OUT_FILE=".superpowers/sdd/review-${BASE}-${HEAD}.md"

echo "# Review Package" > "$OUT_FILE"
echo "" >> "$OUT_FILE"
echo "Base: ${BASE}" >> "$OUT_FILE"
echo "Head: ${HEAD}" >> "$OUT_FILE"
echo "" >> "$OUT_FILE"

echo "## Commits" >> "$OUT_FILE"
echo "" >> "$OUT_FILE"
<<EOF git log --oneline "${BASE}..${HEAD}"
EOF

echo "" >> "$OUT_FILE"
echo "## Diff Stat" >> "$OUT_FILE"
echo "" >> "$OUT_FILE"
<<EOF git diff --stat "${BASE}..${HEAD}"
EOF

echo "" >> "$OUT_FILE"
echo "## Full Diff" >> "$OUT_FILE"
echo "" >> "$OUT_FILE"
<<EOF git diff -U10 "${BASE}..${HEAD}"
EOF

echo "$OUT_FILE"
