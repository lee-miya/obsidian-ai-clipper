#!/usr/bin/env bash
# Extract a single task from the plan file into a brief file.
# Usage: task-brief PLAN_FILE TASK_NUMBER

PLAN_FILE="$1"
TASK_NUM="$2"

if [ -z "$PLAN_FILE" ] || [ -z "$TASK_NUM" ]; then
  echo "Usage: $0 <plan-file> <task-number>"
  exit 1
fi

OUT_FILE=".superpowers/sdd/task-${TASK_NUM}-brief.md"

echo "# Task ${TASK_NUM} Brief" > "$OUT_FILE"
echo "" >> "$OUT_FILE"
echo "Source plan: ${PLAN_FILE}" >> "$OUT_FILE"
echo "" >> "$OUT_FILE"

awk -v n="$TASK_NUM" '
BEGIN { in_task = 0 }
/^## Task [0-9]+:/ {
  if (in_task) { exit }
  match($0, /[0-9]+/)
  task_num = substr($0, RSTART, RLENGTH)
  if (task_num == n) { in_task = 1 }
}
in_task { print }
' "$PLAN_FILE" >> "$OUT_FILE"

echo "$OUT_FILE"
